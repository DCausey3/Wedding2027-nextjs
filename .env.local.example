# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard > Project Settings > API
# Use the "publishable" key (sb_publishable_...), NOT the secret/service_role key

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# ── Wedding Dates ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEDDING_COLOMBIA_DATE=2026-11-07T18:00:00
NEXT_PUBLIC_WEDDING_USA_DATE=2026-12-12T18:00:00

# ── Site URL (used for auth redirects) ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
